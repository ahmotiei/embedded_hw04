# Copy this file to config/api.env and edit the values.
API_LISTEN_URL=http://0.0.0.0:8005

# One or more local SQLite files separated by a colon.
# Usually the API runs on the Master and reads the Master database.
DATABASE_PATHS=/home/amir/master/master.db

# Pinned official Mongoose release downloaded by fetch_mongoose.sh.
MONGOOSE_VERSION=7.21
