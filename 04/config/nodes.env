SNMP_VERSION=2c
SNMP_COMMUNITY=hotelMonitor
SNMP_BASE_OID=.1.3.6.1.4.1.8072.9999.4
SNMP_TIMEOUT=2
SNMP_RETRIES=1

# Run read_all_sensors.sh on the Master VM. The Master agent is local and
# the two Slave agents are reached through their VM addresses.
NODES=(
    "master|127.0.0.1|1161"
    "slave1|192.168.122.18|1161"
    "slave2|192.168.122.190|1161"
)
